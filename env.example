# Example environment configuration for FinalProject
#
# 1. Copy this file to `.env` in the project root:
#    cp env.example .env
#
# 2. Replace placeholder values with your real credentials.
#
# IMPORTANT: Do not commit `.env`. It is listed in `.gitignore`.

# =============================================================================
# Database (PostgreSQL — e.g. Docker maps host port 5433 → container 5432)
# =============================================================================
DB_HOST=localhost
DB_NAME=jobs_db
DB_USER=postgres
DB_PASSWORD=rima@123
DB_PORT=5433

# =============================================================================
# JWT (sessions / API tokens)
# =============================================================================
# Use a long random string in production.
SECRET_KEY=vertex-dev-secret-change-in-prod

# =============================================================================
# Public URLs (backend + emails + OAuth redirects)
# =============================================================================
# Where users open the site (used in emails and some redirects).
APP_URL=http://localhost:3000
# Same idea; used for post-login redirects to the frontend.
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Google OAuth (optional — leave blank to disable “Sign in with Google”)
# =============================================================================
# Create OAuth credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match what you register in Google Cloud (default matches local API).
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# =============================================================================
# Stripe (optional — billing; omit for local dev without payments)
# =============================================================================
# https://dashboard.stripe.com/apikeys — use test keys locally.

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# =============================================================================
# Hugging Face (skills / AI features — optional if you do not call those endpoints)
# =============================================================================
# https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_MODEL=openai/gpt-oss-120b:groq

# =============================================================================
# Email (Resend — optional; without RESEND_API_KEY, email sending is skipped)
# =============================================================================
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender in Resend (default is Resend’s test domain).
RESEND_FROM_EMAIL=onboarding@resend.dev

# =============================================================================
# Frontend (Next.js) — copy these into frontend/.env.local if you need overrides
# =============================================================================
# Defaults match local dev: API at 8000, app at 3000.
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_APP_URL=http://localhost:3000